# ─────────────────────────────────────────────────────────
# GemFort API — environment variables
# Copy to .env and fill in values before running locally.
# Never commit the real .env file.
# ─────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Firebase Admin SDK
# Option A: path to a service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option B: inline values (base64-encode the JSON, or set individual fields)
# FIREBASE_PROJECT_ID=gemfort
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@gemfort.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."

# Firebase Storage bucket (no gs:// prefix)
FIREBASE_STORAGE_BUCKET=gemfort.firebasestorage.app

# Webhook shared secret — used to authenticate Firestore / Auth event calls
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=REPLACE_ME

# Cron secret — used to authenticate scheduled job triggers
# Generate with: openssl rand -hex 32
CRON_SECRET=REPLACE_ME

# News sync — external services
GEMINI_API_KEY=
FIRECRAWL_API_KEY=

# CORS — comma-separated list of allowed origins
# CORS_ORIGINS=https://gemfort.app,https://admin.gemfort.app
